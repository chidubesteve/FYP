# TrustFlow-DT environment variables
# Copy this file to .env and adjust values for your setup.
# .env is gitignored — never commit it.

# MQTT broker URL. Default works with local Mosquitto on the standard port.
TRUSTFLOW_BROKER_URL=mqtt://localhost:1883

# Identifier for the simulated device. Used in the MQTT topic and keypair filename.
TRUSTFLOW_DEVICE_ID=device-001

# Path to the device keypair JSON file. Leave unset to use the default:
# keys/{TRUSTFLOW_DEVICE_ID}.json
# Do NOT set to an empty string — that will cause an error.
# TRUSTFLOW_KEY_PATH=keys/device-001.json

# How often the publisher sends a reading, in milliseconds. Default: 1000 (1 per second).
TRUSTFLOW_INTERVAL_MS=1000

# Auto-stop the publisher after this many milliseconds. Set to 0 to run until Ctrl+C.
TRUSTFLOW_DURATION_MS=0
